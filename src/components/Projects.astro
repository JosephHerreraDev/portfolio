---
import Section from "../components/Section.astro";
import Github from "../icons/Github.astro";

interface Project {
    name: string;
    isActive: boolean;
    startDate: Date;
    endDate: string;
    description: string;
    highlights: string[];
    url?: string | null;
}

const projects: Project[] = [
    {
        name: "Hypertrophy",
        isActive: true,
        startDate: new Date("2025-04-09"),
        endDate: "Currently working",
        description:
            "Full-Stack Application to track training sessions, designed to be simple and effective.",
        highlights: [".Net", "C#", "PostgreSQL"],
        url: "https://github.com/JosephHerreraDev/Hypertrophy",
    },
    {
        name: "Prometheus",
        isActive: true,
        startDate: new Date("2024-03-07"),
        endDate: "Currently working",
        description:
            "A personal \"rice\" or personalized desktop environment, made with Arch, Hyperland, and many more tools.",
        highlights: ["Arch", "Hyperland", "Bash"],
        url: "https://github.com/JosephHerreraDev/prometheus",
    },
];
---

<Section title="Projects">
    <ul class="grid gap-4 -mx-4 [grid-template-columns:repeat(auto-fit,minmax(200px,1fr))] max-[700px]:grid-cols-1 max-[700px]:mx-0">
        {
            projects.map(({ url, description, highlights, name, isActive }) => {
                return (
                    <li
                        class="cursor-pointer"
                        onclick={`window.location.href='/projects/${name.toLocaleLowerCase()}'`}
                    >
                        <article class="rounded-lg border border-[#f2f2f2] gap-4 flex flex-col p-4 h-full max-[700px]:border-none max-[700px]:shadow-[0_1px_1px_#f2f2f2] max-[700px]:p-0 max-[700px]:pb-4">
                            <header class="flex-1">
                                <h3 class="flex items-center gap-2 mb-1">
                                    {name}
                                    {isActive && <span class="text-[rgb(0,188,47)]">&bull;</span>}
                                    {url && (
                                        <a
                                            href={url}
                                            title={`See project ${name} repository`}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            onclick="event.stopPropagation()"
                                        >
                                            <Github />
                                        </a>
                                    )}
                                </h3>
                                <p class="text-xs leading-[1.2rem] mb-1">{description}</p>
                            </header>
                            <footer class="flex flex-wrap gap-1 text-[0.6rem]">
                                {highlights.map((highlight) => {
                                    return (
                                        <span class="rounded-md bg-[#eee] text-[#444] text-[0.6rem] font-medium px-[0.6rem] py-[0.2rem]">
                                            {highlight}
                                        </span>
                                    );
                                })}
                            </footer>
                        </article>
                    </li>
                );
            })
        }
    </ul>
</Section>